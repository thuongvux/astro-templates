---
import Base from "🧊/Base.astro";
import Navbar from "🧩/Navbar.astro";
import { ViewTransitions } from "astro:transitions";
import "./themes/default.css";
type Props = {
  title?: string;
  description?: string;
  class?: string;
  href?: string;
  options?: {
    navbar?: boolean;
    viewTransitions?: boolean;
  };
};
const {
  title,
  description,
  class: className,
  options = { navbar: true, viewTransitions: true },
}: Props = Astro.props;
---

<Base title={title} description={description} class={className}>
  {options.viewTransitions && <ViewTransitions slot="head" />}
  {options.navbar && <Navbar slot="header" />}
  <slot name="head" slot="head" />
  <slot name="header" slot="header" />
  <slot name="footer" slot="footer" />
  <slot />
</Base>
