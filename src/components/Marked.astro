---
import { Marked as createMarked } from "marked";
import markedKatex from "marked-katex-extension";
import { markedHighlight } from "marked-highlight";
import { getHighlighter } from "shikiji";

type Props = {
  id?: string;
  class?: string;
  raw: string;
};
const { id, class: className, raw }: Props = Astro.props;

const highlighter = await getHighlighter({
  langs: [
    "astro",
    "bash",
    "html",
    "javascript",
    "json",
    "markdown",
    "typescript",
  ],
  themes: ["dracula-soft"],
});

const marked = new createMarked(
  markedKatex({
    throwOnError: false,
    trust: true,
    macros: {
      "\\id": "\\htmlId{#2}{\\text{#1}}",
    },
  }),
  markedHighlight({
    langPrefix: "language-",
    highlight(code, lang) {
      return highlighter.codeToHtml(code, {
        lang: lang,
        theme: "dracula-soft",
      });
    },
  }),
);

const html = marked.parse(
  // remove the most common zerowidth characters from the start of the file
  raw.replace(/^[\u200B\u200C\u200D\u200E\u200F\uFEFF]/, ""),
  {
    gfm: true,
  },
);
---

<article id={id} class={className} set:html={html} />

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
  integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV"
  crossorigin="anonymous"
/>

<style is:global>
  .katex {
    .mord.text :not(.mathnormal) {
      @apply font-sans text-base font-light;
    }
    .tag {
      @apply mx-2;
      & span {
        @apply !font-medium;
      }
    }
  }
</style>
