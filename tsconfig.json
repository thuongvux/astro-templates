{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "paths": {
      "#assets/*": ["src/assets/*"],
      "#backend/*": ["src/backend/*"],
      "#components/*": ["src/components/*"],
      "#configs/*": ["src/configs/*"],
      "#layouts/*": ["src/layouts/*"],
      "#public/*": ["public/*"]
    }
  },
  "extends": "astro/tsconfigs/strict"
}
